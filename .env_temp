# 加载环境变量配置文件
# 如果.env文件不存在，将使用系统环境变量

# ========================= 大语言模型API配置 ==========================
MAIN_MODEL=qwen3.5-plus
#微调RL后的摘要模型
SUMMARY_MODEL=qwen3.5-plus
#tokenizer模型路径，需要自己设置，先从modelscope或者huggingface下载下来
TOKENIZER_MODEL=/home/RAG_agent/model/models/Qwen/Qwen3-Embedding-0.6B
#百炼平台api_key
API_KEY=*********
#温度参数
TEMPERATURE=0.8


# ========================= 日志配置 ，可以不修改=============================
LOG_DIR=./log

# ===== 数据库配置 =====
#mysql数据库连接地址
DATABASE_URL=mysql+asyncmy://root:password@localhost:3306/agent_project
#milvus数据库连接地址,不用修改
MILVUS_URL=./RAG_DB/milvus.db
#redis数据库连接参数，根据自己本地配置按需修改
REDIS_HOST=localhost
REDIS_PORT=6379


# ===== 日志级别 =====
LOG_LEVEL=INFO

# ================================= 向量知识库路径配置 =================================
# 文件路径，不用修改
__FILE_PATH=/home/RAG_agent/files/law_md
# 嵌入模型 维度1024，根据自己下载的模型路径修改
EMBEDDING_MODEL=/home/RAG_agent/model/models/Qwen/Qwen3-Embedding-0.6B
# 向量数据库collections名称，可不修改
VECTOR_COLLECTION_NAME=no_sft_flat_db

# 模型编码长度，根据模型修改
EMBEDDING_DIM=1024
# 是否重建向量库，避免每次服务重启都需要重新向量化， True需要重新向量化，False不需要，初次配置本地没有向量库时需要设置为True，后续重启服务时可以设置为False
RE_BUILD=True